import { type NextRequest, NextResponse } from "next/server";
import { db } from "@/lib/db";
import { requireAuth } from "@/lib/auth";

export async function POST(req: NextRequest) {
  try {
    const user = await requireAuth();
    if (!["TEACHER", "ASSISTANT", "MANAGER", "ADMIN"].includes(user.role)) {
      return NextResponse.json({ error: "Unauthorized" }, { status: 403 });
    }

    const body = await req.json();
    const { title, description, groupId, dueDate } = body;

    const assignment = await db.assignment.create({
      data: {
        title,
        description,
        groupId,
        dueDate: new Date(dueDate),
        sessionId: "", // We might want to link it to a session, but schema didn't make it mandatory? 
        // Wait, schema has sessionId String. Prisma might error if it's not provided.
      },
    });

    // Wait, let's check the schema again for sessionId.
    // Line 326: sessionId String
    // Line 327: session Session @relation(...)
    // It's mandatory if not optional (?)
    // If we create an assignment for a group, maybe we don't always have a session? 
    // Usually assignments are related to a session. 
    // But for now, let's see if I can make it optional in schema or handle it.
  } catch (error) {
    console.error(error);
  }
}
