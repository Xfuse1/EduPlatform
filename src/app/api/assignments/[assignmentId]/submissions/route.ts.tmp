import { type NextRequest, NextResponse } from "next/server";
import { db } from "@/lib/db";
import { requireAuth } from "@/lib/auth";

export async function POST(
  req: NextRequest,
  { params }: { params: { assignmentId: string } }
) {
  try {
    const user = await requireAuth();
    if (user.role !== "STUDENT") {
      return NextResponse.json({ error: "Unauthorized" }, { status: 403 });
    }

    const { assignmentId } = params;
    const body = await req.json();
    const { fileUrl, note } = body;

    // Use upsert to allow updating submission
    const submission = await db.assignmentSubmission.upsert({
      where: {
        // We might need a unique index on (assignmentId, studentId) in schema
        // Let's check schema.prisma
        // Line 358: @@index([assignmentId])
        // Line 359: @@index([studentId])
        // No unique index! I should add it.
        id: "", // Placeholder
      },
      update: {
        fileUrl,
        note,
        submittedAt: new Date(),
      },
      create: {
        assignmentId,
        studentId: user.id,
        fileUrl,
        note,
      },
    });

  } catch (error) {
    console.error(error);
  }
}
