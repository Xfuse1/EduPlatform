generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  plan          Plan     @default(FREE)
  planExpiresAt DateTime?
  logoUrl       String?
  themeColor    String   @default("#1A5276")
  phone         String?
  region        String?
  bio           String?
  subjects      String[]
  isActive      Boolean  @default(true)
  smsQuota      Int      @default(50)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users         User[]
  groups        Group[]
  sessions      Session[]
  attendance    Attendance[]
  payments      Payment[]
  notifications Notification[]
  messages      Message[]

  @@index([slug])
}

enum Plan {
  FREE
  BASIC
  PRO
  BUSINESS
}

model User {
  id                String            @id @default(cuid())
  tenantId          String
  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phone             String
  name              String
  role              UserRole
  avatarUrl         String?
  gradeLevel        String?
  parentName        String?
  parentPhone       String?
  isActive          Boolean           @default(true)
  lastLoginAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  enrollments       GroupStudent[]
  attendanceRecords Attendance[]
  markedAttendance  Attendance[]      @relation("MarkedBy")
  studentPayments   Payment[]         @relation("StudentPayments")
  recordedPayments  Payment[]         @relation("RecordedBy")
  sentNotifications Notification[]
  parentOf          ParentStudent[]   @relation("ParentUser")
  childOf           ParentStudent[]   @relation("StudentUser")
  sessions          AuthSession[]
  assignmentSubmissions AssignmentSubmission[]
  sessionRatings    SessionRating[]
  sentMessages      Message[]         @relation("SentMessages")
  receivedMessages  Message[]         @relation("ReceivedMessages")

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tenantId, role])
}

enum UserRole {
  TEACHER
  STUDENT
  PARENT
  ASSISTANT
}

model ParentStudent {
  id           String   @id @default(cuid())
  parentId     String
  parent       User     @relation("ParentUser", fields: [parentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User     @relation("StudentUser", fields: [studentId], references: [id], onDelete: Cascade)
  relationship String   @default("parent")
  createdAt    DateTime @default(now())

  @@unique([parentId, studentId])
}

model Group {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  subject     String
  gradeLevel  String
  days        String[]
  timeStart   String
  timeEnd     String
  room        String?
  maxCapacity Int      @default(40)
  monthlyFee  Int
  color       String   @default("#2E86C1")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  students    GroupStudent[]
  sessions    Session[]
  attendance  Attendance[]
  assignments Assignment[]

  @@index([tenantId])
  @@index([tenantId, isActive])
}

model GroupStudent {
  id         String           @id @default(cuid())
  groupId    String
  group      Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  studentId  String
  student    User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status     EnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime         @default(now())
  droppedAt  DateTime?

  @@unique([groupId, studentId])
  @@index([groupId, status])
  @@index([studentId])
}

enum EnrollmentStatus {
  ACTIVE
  WAITLIST
  ARCHIVED
  DROPPED
}

model Session {
  id         String        @id @default(cuid())
  tenantId   String
  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  groupId    String
  group      Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  date       DateTime      @db.Date
  timeStart  String
  timeEnd    String
  status     SessionStatus @default(SCHEDULED)
  type       SessionType   @default(REGULAR)
  notes      String?

  // QR Attendance Fields
  qrToken     String?   @unique
  qrExpiresAt DateTime?

  createdAt  DateTime      @default(now())
  attendance Attendance[]
  assignments Assignment[]
  ratings     SessionRating[]

  @@unique([groupId, date])
  @@index([tenantId, date])
}

enum SessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SessionType {
  REGULAR
  MAKEUP
  EXTRA
}

model Attendance {
  id         String           @id @default(cuid())
  tenantId   String
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessionId  String
  session    Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  groupId    String
  group      Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  studentId  String
  student    User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status     AttendanceStatus @default(ABSENT)
  markedById String?
  markedBy   User?            @relation("MarkedBy", fields: [markedById], references: [id])
  method     AttendanceMethod @default(MANUAL)
  markedAt   DateTime         @default(now())
  synced     Boolean          @default(true)
  createdAt  DateTime         @default(now())

  @@unique([sessionId, studentId])
  @@index([tenantId, sessionId])
  @@index([tenantId, studentId])
  @@index([studentId, createdAt])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum AttendanceMethod {
  MANUAL
  QR
  GPS
  CODE
}

model Payment {
  id                String        @id @default(cuid())
  tenantId          String
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId         String
  student           User          @relation("StudentPayments", fields: [studentId], references: [id], onDelete: Cascade)
  amount            Int
  month             String
  status            PaymentStatus @default(PENDING)
  method            PaymentMethod @default(CASH)
  installmentNumber Int?
  installmentTotal  Int?
  receiptNumber     String?       @unique
  receiptUrl        String?
  paidAt            DateTime?
  recordedById      String?
  recordedBy        User?         @relation("RecordedBy", fields: [recordedById], references: [id])
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([tenantId, studentId])
  @@index([tenantId, month])
  @@index([tenantId, status])
}

enum PaymentStatus {
  PAID
  PARTIAL
  PENDING
  OVERDUE
}

enum PaymentMethod {
  CASH
  VODAFONE_CASH
  FAWRY
  INSTAPAY
  CARD
}

model Notification {
  id             String             @id @default(cuid())
  tenantId       String
  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           NotificationType
  message        String
  channel        NotificationChannel
  status         NotificationStatus @default(QUEUED)
  recipientPhone String
  sentAt         DateTime?
  errorMessage   String?
  retries        Int                @default(0)
  createdAt      DateTime           @default(now())

  @@index([tenantId, status])
  @@index([userId])
  @@index([status, createdAt])
}

enum NotificationType {
  ATTENDANCE_PRESENT
  ATTENDANCE_ABSENT
  PAYMENT_REMINDER
  PAYMENT_OVERDUE
  CLASS_REMINDER
  ANNOUNCEMENT
}

enum NotificationChannel {
  SMS
  WHATSAPP
  PUSH
}

enum NotificationStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

model OTP {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone, code])
  @@index([phone, createdAt])
}

model AuthSession {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId     String
  token        String   @unique
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([token])
  @@index([refreshToken])
  @@index([expiresAt])
}

model Assignment {
  id          String   @id @default(cuid())
  sessionId   String?
  session     Session? @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  groupId     String
  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime
  createdAt   DateTime @default(now())
  submissions AssignmentSubmission[]

  @@index([sessionId])
  @@index([groupId])
}

model AssignmentSubmission {
  id           String     @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fileUrl      String?
  note         String?
  grade        Int?
  submittedAt  DateTime   @default(now())

  @@unique([assignmentId, studentId])
}

model SessionRating {
  id        String @id @default(cuid())
  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  studentId String
  student   User    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([studentId])
}

model Message {
  id         String    @id @default(cuid())
  tenantId   String
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  senderId   String
  sender     User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User      @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  text       String
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([tenantId])
  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
}
