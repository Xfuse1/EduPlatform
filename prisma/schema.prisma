generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  BASIC
  PRO
  BUSINESS
}

enum UserRole {
  TEACHER
  STUDENT
  PARENT
  ASSISTANT
}

enum EnrollmentStatus {
  ACTIVE
  WAITLIST
  ARCHIVED
  DROPPED
}

enum SessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SessionType {
  REGULAR
  MAKEUP
  EXTRA
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum AttendanceMethod {
  MANUAL
  QR
  GPS
  CODE
  QR_GUEST
}

enum PaymentStatus {
  PAID
  PARTIAL
  PENDING
  OVERDUE
}

enum PaymentMethod {
  CASH
  VODAFONE_CASH
  FAWRY
  INSTAPAY
  CARD
}

enum NotificationType {
  ATTENDANCE_PRESENT
  ATTENDANCE_ABSENT
  PAYMENT_REMINDER
  PAYMENT_OVERDUE
  CLASS_REMINDER
  ANNOUNCEMENT
}

enum NotificationChannel {
  SMS
  WHATSAPP
  PUSH
}

enum NotificationStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Tenant {
  id            String    @id @default(cuid())
  slug          String    @unique
  name          String
  plan          Plan      @default(FREE)
  planExpiresAt DateTime?
  logoUrl       String?
  themeColor    String    @default("#1A5276")
  phone         String?
  region        String?
  bio           String?
  subjects      String[]
  isActive      Boolean   @default(true)
  smsQuota      Int       @default(50)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  users         User[]
  groups        Group[]
  sessions      Session[]
  attendances   Attendance[]
  payments      Payment[]
  notifications Notification[]
  assignments   Assignment[]
  messages      Message[]

  @@index([slug])
}

model User {
  id          String    @id @default(cuid())
  tenantId    String
  phone       String
  name        String
  role        UserRole
  avatarUrl   String?
  gradeLevel  String?
  parentName  String?
  parentPhone String?
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parentStudents      ParentStudent[]      @relation("ParentRelation")
  childStudents       ParentStudent[]      @relation("StudentRelation")
  groupStudents       GroupStudent[]
  attendances         Attendance[]         @relation("StudentAttendance")
  markedAttendances   Attendance[]         @relation("MarkedByAttendance")
  payments            Payment[]            @relation("StudentPayments")
  recordedPayments    Payment[]            @relation("RecordedPayments")
  notifications       Notification[]
  authSessions        AuthSession[]
  assignmentSubmissions AssignmentSubmission[]
  sentMessages        Message[]            @relation("SentMessages")
  receivedMessages    Message[]            @relation("ReceivedMessages")

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tenantId, role])
}

model ParentStudent {
  id           String   @id @default(cuid())
  parentId     String
  studentId    String
  relationship String   @default("parent")
  createdAt    DateTime @default(now())

  parent  User @relation("ParentRelation", fields: [parentId], references: [id], onDelete: Cascade)
  student User @relation("StudentRelation", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
}

model Group {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  subject     String
  gradeLevel  String
  days        String[]
  timeStart   String
  timeEnd     String
  room        String?
  maxCapacity Int      @default(40)
  monthlyFee  Int
  color       String   @default("#2E86C1")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  groupStudents GroupStudent[]
  sessions      Session[]
  attendances   Attendance[]
  assignments   Assignment[]

  @@index([tenantId])
  @@index([tenantId, isActive])
}

model GroupStudent {
  id        String           @id @default(cuid())
  groupId   String
  studentId String
  status    EnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime        @default(now())
  droppedAt  DateTime?

  group   Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student User  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupId, studentId])
  @@index([groupId, status])
  @@index([studentId])
}

model Session {
  id        String        @id @default(cuid())
  tenantId  String
  groupId   String
  date      DateTime      @db.Date
  timeStart String
  timeEnd   String
  status    SessionStatus @default(SCHEDULED)
  type      SessionType   @default(REGULAR)
  notes     String?
  qrToken   String?       @unique
  qrExpiresAt DateTime?
  createdAt DateTime      @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  group       Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  attendances Attendance[]

  @@unique([groupId, date])
  @@index([tenantId, date])
}

model Attendance {
  id         String           @id @default(cuid())
  tenantId   String
  sessionId  String
  groupId    String
  studentId  String
  status     AttendanceStatus @default(ABSENT)
  markedById String?
  method     AttendanceMethod @default(MANUAL)
  markedAt   DateTime         @default(now())
  synced     Boolean          @default(true)
  createdAt  DateTime         @default(now())

  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student   User     @relation("StudentAttendance", fields: [studentId], references: [id], onDelete: Cascade)
  markedBy  User?    @relation("MarkedByAttendance", fields: [markedById], references: [id], onDelete: SetNull)

  @@unique([sessionId, studentId])
  @@index([tenantId, sessionId])
  @@index([tenantId, studentId])
  @@index([studentId, createdAt])
}

model Payment {
  id                String        @id @default(cuid())
  tenantId          String
  studentId         String
  amount            Int
  month             String
  status            PaymentStatus @default(PENDING)
  method            PaymentMethod @default(CASH)
  installmentNumber Int?
  installmentTotal  Int?
  receiptNumber     String?       @unique
  receiptUrl        String?
  paidAt            DateTime?
  recordedById      String?
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  student    User   @relation("StudentPayments", fields: [studentId], references: [id], onDelete: Cascade)
  recordedBy User?  @relation("RecordedPayments", fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([tenantId, studentId])
  @@index([tenantId, month])
  @@index([tenantId, status])
}

model Notification {
  id             String              @id @default(cuid())
  tenantId       String
  userId         String
  type           NotificationType
  message        String
  channel        NotificationChannel
  status         NotificationStatus  @default(QUEUED)
  recipientPhone String
  sentAt         DateTime?
  errorMessage   String?
  retries        Int                 @default(0)
  createdAt      DateTime            @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([userId])
  @@index([status, createdAt])
}

model OTP {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([phone, code])
  @@index([phone, createdAt])
}

model AuthSession {
  id           String   @id @default(cuid())
  userId       String
  tenantId     String
  token        String   @unique
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([refreshToken])
  @@index([expiresAt])
}

// ─── Assignment System ────────────────────────────────────────────────────────

model Assignment {
  id           String   @id @default(cuid())
  tenantId     String
  groupId      String
  title        String
  description  String?
  dueDate      DateTime?
  answerKeyUrl String?
  fileUrl      String?
  maxGrade     Int      @default(100)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant      Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  group       Group                  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  submissions AssignmentSubmission[]

  @@index([tenantId])
  @@index([groupId])
}

model AssignmentSubmission {
  id           String   @id @default(cuid())
  assignmentId String
  studentId    String
  fileUrl      String?
  note         String?
  grade        Int?
  gradedByAi   Boolean  @default(false)
  aiGrade      Int?
  aiFeedback   String?
  submittedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
}

// ─── Messaging System ────────────────────────────────────────────────────────

model Message {
  id         String   @id @default(cuid())
  tenantId   String
  senderId   String
  receiverId String
  text       String
  readAt     DateTime?
  createdAt  DateTime @default(now())

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sender   User   @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User   @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([senderId, receiverId])
  @@index([createdAt])
}
