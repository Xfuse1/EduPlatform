// ============================================
// EduPlatform — Prisma Schema (MVP Only)
// ============================================
//
// RULE: This schema contains ONLY what the MVP needs.
// DO NOT add Phase 2+ models (exams, homework, points, streaks, etc.)
// When we reach those phases, we add models via new migrations.
//
// RULE: Every tenant-scoped model MUST have tenantId.
// A query without tenantId = security bug = data leak.
//
// RULE: DO NOT modify existing models after Day 1 without team agreement.
//       Adding NEW models for future phases is fine.
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// TENANT — The teacher or center
// ============================================
model Tenant {
  id            String   @id @default(cuid())
  slug          String   @unique              // subdomain: ahmed.eduplatform.com
  name          String                         // "أ/ أحمد حسن"
  plan          Plan     @default(FREE)
  planExpiresAt DateTime?
  logoUrl       String?
  themeColor    String   @default("#1A5276")
  phone         String?                        // owner's phone
  region        String?                        // "سوهاج"
  bio           String?                        // for public profile
  subjects      String[]                       // ["رياضيات", "فيزياء"]
  isActive      Boolean  @default(true)
  smsQuota      Int      @default(50)          // remaining SMS this month
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  users         User[]
  groups        Group[]
  sessions      Session[]
  attendance    Attendance[]
  payments      Payment[]
  notifications Notification[]

  @@index([slug])
}

enum Plan {
  FREE       // 0 EGP — up to 30 students, 50 SMS/mo
  BASIC      // 199 EGP — up to 100 students, 200 SMS/mo
  PRO        // 499 EGP — up to 500 students, 1000 SMS/mo
  BUSINESS   // 999 EGP — 500+ students, unlimited SMS
}

// ============================================
// USER — Single table for all roles
// ============================================
// One table, differentiated by `role`.
// Students have parentName + parentPhone directly (no separate parent table).
// Parents as users are created when they log into the parent dashboard.
// ============================================
model User {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phone        String
  name         String
  role         UserRole
  avatarUrl    String?
  gradeLevel   String?                         // students: "3 ثانوي"
  parentName   String?                         // students: parent's name
  parentPhone  String?                         // students: parent's phone for notifications
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  enrollments       GroupStudent[]
  attendanceRecords Attendance[]                // student's attendance
  markedAttendance  Attendance[]  @relation("MarkedBy")  // teacher/assistant marked
  studentPayments   Payment[]     @relation("StudentPayments")
  recordedPayments  Payment[]     @relation("RecordedBy")
  sentNotifications Notification[]
  parentOf          ParentStudent[] @relation("ParentUser")
  childOf           ParentStudent[] @relation("StudentUser")

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@index([tenantId, role])
}

enum UserRole {
  TEACHER
  STUDENT
  PARENT
  ASSISTANT
}

// ============================================
// PARENT-STUDENT LINK
// ============================================
// Links a parent user to their children (students).
// Used when parent logs in to see multiple children.
// For notifications, we use student.parentPhone directly (no join needed).
// ============================================
model ParentStudent {
  id           String @id @default(cuid())
  parentId     String
  parent       User   @relation("ParentUser", fields: [parentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User   @relation("StudentUser", fields: [studentId], references: [id], onDelete: Cascade)
  relationship String @default("parent")  // father, mother, guardian
  createdAt    DateTime @default(now())

  @@unique([parentId, studentId])
}

// ============================================
// GROUP — A study group (e.g., "Math Grade 12 — Group A")
// ============================================
// Days stored as JSON array: ["saturday", "tuesday"]
// Time is the same for all days. If different times per day needed
// later, we'll add a GroupSchedule model in a future migration.
// ============================================
model Group {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String                            // "رياضيات 3 ثانوي - مجموعة أ"
  subject     String                            // "رياضيات"
  gradeLevel  String                            // "3 ثانوي"
  days        String[]                          // ["saturday", "tuesday"]
  timeStart   String                            // "16:00" (24h format)
  timeEnd     String                            // "17:30"
  room        String?                           // "قاعة 3"
  maxCapacity Int      @default(40)
  monthlyFee  Int                               // whole EGP (no piasters)
  color       String   @default("#2E86C1")      // hex for UI
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  students    GroupStudent[]
  sessions    Session[]
  attendance  Attendance[]

  @@index([tenantId])
  @@index([tenantId, isActive])
}

// ============================================
// GROUP-STUDENT ENROLLMENT
// ============================================
model GroupStudent {
  id         String           @id @default(cuid())
  groupId    String
  group      Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  studentId  String
  student    User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status     EnrollmentStatus @default(ACTIVE)
  enrolledAt DateTime         @default(now())
  droppedAt  DateTime?

  @@unique([groupId, studentId])
  @@index([groupId, status])
  @@index([studentId])
}

enum EnrollmentStatus {
  ACTIVE
  WAITLIST
  ARCHIVED
  DROPPED
}

// ============================================
// SESSION — An actual class occurrence
// ============================================
// Auto-generated from group schedule (if today is Saturday and group
// meets on Saturdays, create a session). Can also be created manually
// for makeup classes.
// ============================================
model Session {
  id        String        @id @default(cuid())
  tenantId  String
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  groupId   String
  group     Group         @relation(fields: [groupId], references: [id], onDelete: Cascade)
  date      DateTime      @db.Date
  timeStart String
  timeEnd   String
  status    SessionStatus @default(SCHEDULED)
  type      SessionType   @default(REGULAR)
  notes     String?
  createdAt DateTime      @default(now())

  // Relations
  attendance Attendance[]

  @@unique([groupId, date])
  @@index([tenantId, date])
}

enum SessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SessionType {
  REGULAR
  MAKEUP
  EXTRA
}

// ============================================
// ATTENDANCE — Per-student per-session record
// ============================================
model Attendance {
  id         String           @id @default(cuid())
  tenantId   String
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessionId  String
  session    Session          @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  groupId    String
  group      Group            @relation(fields: [groupId], references: [id], onDelete: Cascade)
  studentId  String
  student    User             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status     AttendanceStatus @default(ABSENT)
  markedById String?
  markedBy   User?            @relation("MarkedBy", fields: [markedById], references: [id])
  method     AttendanceMethod @default(MANUAL)
  markedAt   DateTime         @default(now())
  synced     Boolean          @default(true)   // false = queued from offline
  createdAt  DateTime         @default(now())

  @@unique([sessionId, studentId])
  @@index([tenantId, sessionId])
  @@index([tenantId, studentId])
  @@index([studentId, createdAt])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum AttendanceMethod {
  MANUAL      // teacher taps on phone
  QR          // Phase 2
  GPS         // Phase 3
  CODE        // Phase 2
}

// ============================================
// PAYMENT — Monthly payment record per student
// ============================================
// Simple: one record per student per month.
// No payment_cycles table — teacher just records "paid" or "not paid".
// Installment support: multiple Payment records for same month with
// installmentNumber (1/3, 2/3, 3/3).
// ============================================
model Payment {
  id                String        @id @default(cuid())
  tenantId          String
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  studentId         String
  student           User          @relation("StudentPayments", fields: [studentId], references: [id], onDelete: Cascade)
  amount            Int                                // whole EGP
  month             String                             // "2026-03"
  status            PaymentStatus @default(PENDING)
  method            PaymentMethod @default(CASH)
  installmentNumber Int?                               // 1, 2, 3...
  installmentTotal  Int?                               // total installments
  receiptNumber     String?       @unique              // "RCP-ahmed-20260313-001"
  receiptUrl        String?                            // PDF URL
  paidAt            DateTime?
  recordedById      String?
  recordedBy        User?         @relation("RecordedBy", fields: [recordedById], references: [id])
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([tenantId, studentId])
  @@index([tenantId, month])
  @@index([tenantId, status])
}

enum PaymentStatus {
  PAID
  PARTIAL
  PENDING
  OVERDUE
}

enum PaymentMethod {
  CASH             // MVP: cash only
  VODAFONE_CASH    // Phase 3
  FAWRY            // Phase 3
  INSTAPAY         // Phase 3
  CARD             // Phase 3
}

// ============================================
// NOTIFICATION — SMS/WhatsApp/Push log
// ============================================
model Notification {
  id           String              @id @default(cuid())
  tenantId     String
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId       String
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         NotificationType
  message      String
  channel      NotificationChannel
  status       NotificationStatus  @default(QUEUED)
  recipientPhone String                           // denormalized for quick send
  sentAt       DateTime?
  errorMessage String?
  retries      Int                 @default(0)
  createdAt    DateTime            @default(now())

  @@index([tenantId, status])
  @@index([userId])
  @@index([status, createdAt])            // for retry worker
}

enum NotificationType {
  ATTENDANCE_PRESENT
  ATTENDANCE_ABSENT
  PAYMENT_REMINDER
  PAYMENT_OVERDUE
  CLASS_REMINDER
  ANNOUNCEMENT
}

enum NotificationChannel {
  SMS
  WHATSAPP
  PUSH
}

enum NotificationStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

// ============================================
// AUTH: OTP + Sessions
// ============================================
model OTP {
  id        String   @id @default(cuid())
  phone     String
  code      String                               // 6-digit numeric
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)                 // rate limit: max 3 attempts
  createdAt DateTime @default(now())

  @@index([phone, code])
  @@index([phone, createdAt])                    // rate limit: max 3 OTPs per 15 min
}

model AuthSession {
  id           String   @id @default(cuid())
  userId       String
  tenantId     String
  token        String   @unique
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([token])
  @@index([refreshToken])
  @@index([expiresAt])                           // cleanup expired sessions
}

