# Database
DATABASE_URL="postgresql://user:password@localhost:5432/eduplatform"

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# JWT
JWT_SECRET="your-secret-key-here"

# Redis (optional)
REDIS_URL="redis://localhost:6379"
REDIS_TOKEN="optional-token"

# SMS Provider (optional)
SMS_PROVIDER_URL="https://api.sms-provider.com"
SMS_PROVIDER_API_KEY="your-api-key"

# WhatsApp (optional)
WHATSAPP_API_URL="https://api.whatsapp.com"
WHATSAPP_ACCESS_TOKEN="your-token"

# Theme
NEXT_PUBLIC_DEFAULT_THEME="light"

# Kashier Payment Gateway
KASHIER_MERCHANT_ID="your-merchant-id"
KASHIER_API_KEY="your-api-key"
KASHIER_WEBHOOK_SECRET="your-webhook-secret"

# Encryption (for storing teacher API keys)
ENCRYPTION_KEY="32-character-hex-key-for-aes256"
