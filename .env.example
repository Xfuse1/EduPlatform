# Public app URL used for links, redirects, and metadata.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Preferred default theme: light | dark | system
NEXT_PUBLIC_DEFAULT_THEME=system

# PostgreSQL connection string for Prisma.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eduplatform

# JWT secret for auth/session signing.
JWT_SECRET=replace-with-a-long-random-secret

# Optional Redis REST endpoint for tenant cache, OTP rate limiting, and queues.
# Leave blank in MVP local setup to fall back to direct DB reads.
REDIS_URL=
REDIS_TOKEN=

# Optional SMS provider config. MVP can stay empty and use console logging.
SMS_PROVIDER_URL=
SMS_PROVIDER_API_KEY=

# Optional WhatsApp provider config for parent notifications.
WHATSAPP_API_URL=
WHATSAPP_ACCESS_TOKEN=
